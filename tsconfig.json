{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "allowImportingTsExtensions": true
  },
  "include": ["scripts/**/*.ts", "meta.ts"],
  "exclude": ["node_modules", "sources", "vendor", "skills"]
}
